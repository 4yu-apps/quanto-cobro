<?xml version="1.0" encoding="utf-8"?>
<!-- O charcoal do splash, com vinheta.

     Aqui morava um gradiente VERDE (#0D2C21 → #071612), e ele era o fundo que
     o app já tinha abandonado: o comentário em `color_scheme.dart` diz que o
     esmeralda "só parecia sujo/antigo porque o fundo também era verde". Sobre
     verde, a marca perdia justamente o brilho que a mudança de tema ganhou.

     Três paradas (start / center / end), não duas: a do meio segura o tom até
     ~60% do raio e só então a borda cai. É o que faz a vinheta ser sentida e
     não vista — com duas o degradê é linear e parece fundo mal resolvido.

     Radial, e com raio até perto dos cantos: raio curto fecha a vinheta antes
     deles e deixa um anel escuro visível, que lê como erro de arte. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <gradient
        android:type="radial"
        android:centerX="0.5"
        android:centerY="0.5"
        android:gradientRadius="90%p"
        android:startColor="#1B2620"
        android:centerColor="#131A16"
        android:endColor="#050807"/>
</shape>
